# Gradle
.gradle/
build/

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store

# Fabric Loom cache (inside project)
.loom-cache/
run/

# CI release staging (renamed jars for Modrinth upload)
upload/

# Secrets — never commit tokens/keys.
#
# Keep runtime tokens and configs out of git. Real key protection: set
# BLOCKPAL_API_TOKEN as an environment variable so the token never lands on disk.
# See wiki/Security.md.
*.env
.env
huggingface.env
!huggingface.env
`huggingface.env
* `huggingface.env

secrets.properties
# Runtime config that can contain the (obfuscated) API token — never commit it.
# (Specifically the game's config/blockpal/ folder — NOT the source 'config'
# package, which is com/milkdromeda/blockpal/config/.)
config/blockpal/
run/config/
# Loose token/secret files people sometimes drop in a repo by accident.
*.token
*.secret
hf_token*
blockpal-token*
# Java source files are intentionally ignored so new implementation files are not
# staged accidentally. If a Java file must be added to version control, review it
# for secret-handling risks first and force-add it deliberately.
*.java
